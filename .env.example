# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lifecraft
DB_USER=lifecraft
DB_PASSWORD=replace_with_a_long_random_database_password

# Server
PORT=3000
SESSION_SECRET=replace_with_at_least_32_random_characters
COOKIE_SECURE=false
TRUST_PROXY=false

# Initial admin account
# Use a unique password with at least 12 characters. Never commit your real .env.
ADMIN_USERNAME=replace_with_your_username
ADMIN_PASSWORD=replace_with_a_long_unique_password

# Google Calendar integration (optional)
# Store the key outside the repo or in a local ignored file.
# GOOGLE_SERVICE_ACCOUNT_FILE=../private/google-service-account.json
